{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2015"],
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@keyfi/sdk": ["sdk/src"]
    }
  },
  "include": ["tests/**/*.ts", "sdk/**/*.ts", "migrations/**/*.ts", "scripts/**/*.ts"]
}
